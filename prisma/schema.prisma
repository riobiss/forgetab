// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String      @map("password_hash")
  createdAt    DateTime    @default(now()) @map("created_at")
  rpgs         Rpg[]
  rpgMembers   RpgMember[]
  characters   RpgCharacter[]
  characterCreationRequests RpgCharacterCreationRequest[]

  @@map("users")
}

enum RpgVisibility {
  private
  public
}

enum BaseItemType {
  weapon
  armor
  consumable
  accessory
  material
  quest
}

enum BaseItemRarity {
  common
  uncommon
  rare
  epic
  legendary
}

enum RpgMemberStatus {
  pending
  accepted
  rejected
}

enum CharacterCreationRequestStatus {
  pending
  accepted
  rejected
}

enum RpgCharacterType {
  player
  npc
  monster
}

model Rpg {
  id                 String                 @id @default(cuid())
  ownerId            String                 @map("owner_id")
  owner              User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title              String
  description        String
  visibility         RpgVisibility          @default(private)
  createdAt          DateTime               @default(now()) @map("created_at")
  baseItems          BaseItem[]
  attributeTemplates RpgAttributeTemplate[]
  statusTemplates    RpgStatusTemplate[]
  characters         RpgCharacter[]
  members            RpgMember[]
  characterCreationRequests RpgCharacterCreationRequest[]

  @@index([ownerId])
  @@map("rpgs")
}

model BaseItem {
  id        String         @id @default(cuid())
  rpgId     String         @map("rpg_id")
  rpg       Rpg            @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  name      String
  type      BaseItemType
  rarity    BaseItemRarity @default(common)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @default(now()) @map("updated_at")

  @@index([rpgId])
  @@map("baseitems")
}

model RpgAttributeTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_attribute_templates")
}

model RpgCharacter {
  id            String           @id @default(cuid())
  rpgId         String           @map("rpg_id")
  rpg           Rpg              @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  createdByUserId String?        @map("created_by_user_id")
  createdByUser User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  name          String
  characterType RpgCharacterType @default(player) @map("character_type")
  life          Int              @default(0)
  defense       Int              @default(0)
  mana          Int              @default(0)
  stamina       Int              @default(0)
  sanity        Int              @default(0)
  statuses      Json
  attributes    Json
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @map("updated_at")

  @@index([rpgId])
  @@index([createdByUserId])
  @@index([rpgId, createdByUserId])
  @@map("rpg_characters")
}

model RpgStatusTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_status_templates")
}

model RpgMember {
  id         String          @id @default(cuid())
  rpgId      String          @map("rpg_id")
  userId     String          @map("user_id")
  status     RpgMemberStatus @default(pending)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @map("updated_at")
  requestedAt DateTime       @default(now()) @map("requested_at")
  respondedAt DateTime?      @map("responded_at")
  rpg        Rpg             @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rpgId, userId])
  @@index([rpgId])
  @@index([userId])
  @@map("rpg_members")
}

model RpgCharacterCreationRequest {
  id          String                         @id @default(cuid())
  rpgId       String                         @map("rpg_id")
  userId      String                         @map("user_id")
  status      CharacterCreationRequestStatus @default(pending)
  createdAt   DateTime                       @default(now()) @map("created_at")
  updatedAt   DateTime                       @default(now()) @map("updated_at")
  requestedAt DateTime                       @default(now()) @map("requested_at")
  respondedAt DateTime?                      @map("responded_at")
  rpg         Rpg                            @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  user        User                           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rpgId, userId])
  @@index([rpgId])
  @@index([userId])
  @@map("rpg_character_creation_requests")
}
