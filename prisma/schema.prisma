// learn more about it in the docs: https://pris.ly/d/prisma-schema

// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String      @id @default(cuid())
  name         String
  email        String      @unique
  passwordHash String      @map("password_hash")
  createdAt    DateTime    @default(now()) @map("created_at")
  rpgs         Rpg[]
  rpgMembers   RpgMember[]
  characters   RpgCharacter[]
  characterCreationRequests RpgCharacterCreationRequest[]

  @@map("users")
}

enum RpgVisibility {
  private
  public
}

enum BaseItemType {
  weapon
  armor
  consumable
  accessory
  material
  quest
}

enum BaseItemRarity {
  common
  uncommon
  rare
  epic
  legendary
}

enum RpgMemberStatus {
  pending
  accepted
  rejected
}

enum CharacterCreationRequestStatus {
  pending
  accepted
  rejected
}

enum RpgCharacterType {
  player
  npc
  monster
}

model Rpg {
  id                 String                 @id @default(cuid())
  ownerId            String                 @map("owner_id")
  owner              User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title              String
  description        String
  visibility         RpgVisibility          @default(private)
  useClassRaceBonuses Boolean               @default(false) @map("use_class_race_bonuses")
  useInventoryWeightLimit Boolean           @default(false) @map("use_inventory_weight_limit")
  createdAt          DateTime               @default(now()) @map("created_at")
  baseItems          BaseItem[]
  attributeTemplates RpgAttributeTemplate[]
  statusTemplates    RpgStatusTemplate[]
  skillTemplates     RpgSkillTemplate[]
  raceTemplates      RpgRaceTemplate[]
  classTemplates     RpgClassTemplate[]
  characterIdentityTemplates RpgCharacterIdentityTemplate[]
  characterCharacteristicTemplates RpgCharacterCharacteristicTemplate[]
  characters         RpgCharacter[]
  inventoryItems     RpgCharacterInventoryItem[]
  members            RpgMember[]
  characterCreationRequests RpgCharacterCreationRequest[]

  @@index([ownerId])
  @@map("rpgs")
}

model BaseItem {
  id        String         @id @default(cuid())
  rpgId     String         @map("rpg_id")
  rpg       Rpg            @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  name      String
  description String?
  type      BaseItemType
  rarity    BaseItemRarity @default(common)
  damage    String?
  range     String?
  ability   String?
  abilityName String?      @map("ability_name")
  effect    String?
  effectName String?       @map("effect_name")
  abilities Json?
  effects   Json?
  weight    Float?
  duration  String?
  durability Int?
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @default(now()) @map("updated_at")
  inventories RpgCharacterInventoryItem[]

  @@index([rpgId])
  @@map("baseitems")
}

model RpgAttributeTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_attribute_templates")
}

model RpgCharacter {
  id            String           @id @default(cuid())
  rpgId         String           @map("rpg_id")
  rpg           Rpg              @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  createdByUserId String?        @map("created_by_user_id")
  createdByUser User?            @relation(fields: [createdByUserId], references: [id], onDelete: SetNull)
  name          String
  image         String?
  raceKey       String?          @map("race_key")
  classKey      String?          @map("class_key")
  characterType RpgCharacterType @default(player) @map("character_type")
  visibility    RpgVisibility    @default(public)
  maxCarryWeight Float?          @map("max_carry_weight")
  life          Int              @default(0)
  defense       Int              @default(0)
  mana          Int              @default(0)
  stamina       Int              @default(0)
  sanity        Int              @default(0)
  statuses      Json
  currentStatuses Json?          @map("current_statuses")
  attributes    Json
  skills        Json
  identity      Json?            @map("identity")
  characteristics Json?          @map("characteristics")
  createdAt     DateTime         @default(now()) @map("created_at")
  updatedAt     DateTime         @default(now()) @map("updated_at")
  inventoryItems RpgCharacterInventoryItem[]

  @@index([rpgId])
  @@index([createdByUserId])
  @@index([rpgId, createdByUserId])
  @@index([rpgId, raceKey])
  @@index([rpgId, classKey])
  @@map("rpg_characters")
}

model RpgCharacterIdentityTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  required  Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_character_identity_templates")
}

model RpgCharacterCharacteristicTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  required  Boolean  @default(true)
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_character_characteristic_templates")
}

model RpgCharacterInventoryItem {
  id          String       @id @default(cuid())
  rpgId       String       @map("rpg_id")
  characterId String       @map("character_id")
  baseItemId  String       @map("base_item_id")
  quantity    Int          @default(1)
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @default(now()) @map("updated_at")
  rpg         Rpg          @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  character   RpgCharacter @relation(fields: [characterId], references: [id], onDelete: Cascade)
  baseItem    BaseItem     @relation(fields: [baseItemId], references: [id], onDelete: Cascade)

  @@unique([characterId, baseItemId])
  @@index([rpgId])
  @@index([characterId])
  @@index([baseItemId])
  @@map("rpg_character_inventory_items")
}

model RpgStatusTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_status_templates")
}

model RpgSkillTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_skill_templates")
}

model RpgRaceTemplate {
  id               String   @id @default(cuid())
  rpgId            String   @map("rpg_id")
  rpg              Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key              String
  label            String
  attributeBonuses Json     @map("attribute_bonuses")
  skillBonuses     Json     @map("skill_bonuses")
  lore             Json     @map("lore")
  position         Int
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_race_templates")
}

model RpgClassTemplate {
  id               String   @id @default(cuid())
  rpgId            String   @map("rpg_id")
  rpg              Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key              String
  label            String
  attributeBonuses Json     @map("attribute_bonuses")
  skillBonuses     Json     @map("skill_bonuses")
  position         Int
  createdAt        DateTime @default(now()) @map("created_at")
  updatedAt        DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_class_templates")
}

model RpgMember {
  id         String          @id @default(cuid())
  rpgId      String          @map("rpg_id")
  userId     String          @map("user_id")
  status     RpgMemberStatus @default(pending)
  createdAt  DateTime        @default(now()) @map("created_at")
  updatedAt  DateTime        @default(now()) @map("updated_at")
  requestedAt DateTime       @default(now()) @map("requested_at")
  respondedAt DateTime?      @map("responded_at")
  rpg        Rpg             @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  user       User            @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rpgId, userId])
  @@index([rpgId])
  @@index([userId])
  @@map("rpg_members")
}

model RpgCharacterCreationRequest {
  id          String                         @id @default(cuid())
  rpgId       String                         @map("rpg_id")
  userId      String                         @map("user_id")
  status      CharacterCreationRequestStatus @default(pending)
  createdAt   DateTime                       @default(now()) @map("created_at")
  updatedAt   DateTime                       @default(now()) @map("updated_at")
  requestedAt DateTime                       @default(now()) @map("requested_at")
  respondedAt DateTime?                      @map("responded_at")
  rpg         Rpg                            @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  user        User                           @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([rpgId, userId])
  @@index([rpgId])
  @@index([userId])
  @@map("rpg_character_creation_requests")
}

