// Looking for ways to speed up your queries, or scale easily with your serverless or edge functions?
// Try Prisma Accelerate: https://pris.ly/cli/accelerate-init

generator client {
  provider = "prisma-client"
  output   = "../generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(cuid())
  name         String
  email        String   @unique
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  rpgs         Rpg[]

  @@map("users")
}

enum RpgVisibility {
  private
  public
}

enum BaseItemType {
  weapon
  armor
  consumable
  accessory
  material
  quest
}

enum BaseItemRarity {
  common
  uncommon
  rare
  epic
  legendary
}

model Rpg {
  id                 String                 @id @default(cuid())
  ownerId            String                 @map("owner_id")
  owner              User                   @relation(fields: [ownerId], references: [id], onDelete: Cascade)
  title              String
  description        String
  visibility         RpgVisibility          @default(private)
  createdAt          DateTime               @default(now()) @map("created_at")
  baseItems          BaseItem[]
  attributeTemplates RpgAttributeTemplate[]
  characters         RpgCharacter[]

  @@index([ownerId])
  @@map("rpgs")
}

model BaseItem {
  id        String         @id @default(cuid())
  rpgId     String         @map("rpg_id")
  rpg       Rpg            @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  name      String
  type      BaseItemType
  rarity    BaseItemRarity @default(common)
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @default(now()) @map("updated_at")

  @@index([rpgId])
  @@map("baseitems")
}

model RpgAttributeTemplate {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  key       String
  label     String
  position  Int
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@unique([rpgId, key])
  @@index([rpgId])
  @@map("rpg_attribute_templates")
}

model RpgCharacter {
  id        String   @id @default(cuid())
  rpgId     String   @map("rpg_id")
  rpg       Rpg      @relation(fields: [rpgId], references: [id], onDelete: Cascade)
  name      String
  attributes Json
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @default(now()) @map("updated_at")

  @@index([rpgId])
  @@map("rpg_characters")
}
